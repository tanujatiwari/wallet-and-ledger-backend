// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "wallet"]
}

enum UserStatus {
  active
  archived

  @@schema("auth")
}

model User {
  id          String     @id @default(uuid(7))
  email       String     @unique
  displayName String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  sessions    Session[]
  password    String?
  wallets     Wallet[]
  status      UserStatus @default(active)

  @@schema("auth")
}

model Device {
  id            String    @id @default(uuid(7))
  identifier    String    @unique
  isBlacklisted Boolean   @default(false)
  sessions      Session[]

  @@schema("auth")
}

model Session {
  id            String         @id @default(uuid(7))
  createdAt     DateTime       @default(now())
  isActive      Boolean        @default(false)
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  deviceId      String
  device        Device         @relation(fields: [deviceId], references: [id])
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([deviceId])
  @@schema("auth")
}

model RefreshToken {
  refreshToken           String        @id
  createdAt              DateTime      @default(now())
  sessionId              String
  session                Session       @relation(fields: [sessionId], references: [id])
  isRevoked              Boolean       @default(false)
  rotateAfter            DateTime
  expiresAt              DateTime
  previousRefreshTokenId String?       @unique
  previousRefreshToken   RefreshToken? @relation("RefreshTokenPrevious", fields: [previousRefreshTokenId], references: [refreshToken], onUpdate: Cascade, onDelete: SetNull)
  nextRefreshToken       RefreshToken? @relation("RefreshTokenPrevious")

  @@index([sessionId])
  @@schema("auth")
}

model Wallet {
  id        String    @id @default(uuid(7))
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  createdAt DateTime  @default(now())
  journals  Journal[]
  balance   Int       @default(0)

  @@index([userId])
  @@schema("wallet")
}

model Transaction {
  id           String    @id @default(uuid(7))
  description  String
  createdAt    DateTime  @default(now())
  journalEntry Journal[]

  @@schema("wallet")
}

model Journal {
  id            String      @id @default(uuid(7))
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  walletId      String
  wallet        Wallet      @relation(fields: [walletId], references: [id])
  amount        Int

  @@index([walletId, transactionId])
  @@schema("wallet")
}

enum ScheduledStatus {
  completed
  upcoming
  cancelled
  processing
  failed

  @@schema("wallet")
}

model ScheduledTransfer {
  id           String          @id @default(uuid(7))
  fromWalletId String
  toWalletId   String
  amount       Int
  scheduledAt  DateTime
  createdAt    DateTime        @default(now())
  status       ScheduledStatus @default(upcoming)
  retryCount   Int             @default(0)

  @@index([status, scheduledAt, retryCount])
  @@schema("wallet")
}

enum KeyStatus {
  processing
  completed
  failed

  @@schema("wallet")
}

model IdempotencyKeys {
  key         String    @id
  payloadHash String
  status      KeyStatus @default(processing)
  createdAt   DateTime  @default(now())
  result      Json
  expiresAt   DateTime

  @@schema("wallet")
}

enum EventType {
  transferCompleted
  fundsAdded

  @@schema("wallet")
}

enum EventStatus {
  pending
  published

  @@schema("wallet")
}

model events {
  id        String      @id @default(uuid(7))
  type      EventType
  payload   Json
  createdAt DateTime    @default(now())
  status    EventStatus @default(pending)

  @@schema("wallet")
}
